<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PageNavigationAppAvalonia.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:PageNavigationAppAvalonia.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="PageNavigationAppAvalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="PageNavigationAppAvalonia"
        Height="600"
        Width="850"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1">
    
    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
                     to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    <Border CornerRadius="20" Background="{DynamicResource WindowSurfaceBrush}" Margin="10" ClipToBounds="True" x:DataType="viewModels:MainWindowViewModel">
        <Grid RowDefinitions="Auto,*">
            
            <!-- Title Bar -->
            <Border Name="TitleBar" Height="40" Background="{DynamicResource TitleBarBrush}" Grid.Row="0" Cursor="Hand">
                    
                <!-- grilla para ordenar titlebar -->
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,0">
                    <!-- grupo de botones -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Classes="window-btn minimize-btn" Grid.Column="1" Click="OnMinimizeClick"/> 
                        <Button Classes="window-btn close-btn" Grid.Column="2" Click="OnCloseClick"/>
                    </StackPanel>
                    
                    <!-- icono con titulo -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Image Source="/Assets/avalonia-logo.ico" Width="18" Height="18"/>
                        <!-- titulo centrado -->
                        <TextBlock Text="Page Navigation App using Avalonia UI" Foreground="{DynamicResource TextOnDarkBrush}" FontWeight="SemiBold"/>
                    </StackPanel>
                    
                    <!-- spacer para balancear -->
                    <Border Grid.Column="0" Width="44"/>
                </Grid>
            </Border>
            
            <!-- Area del contenido -->
            <Grid Grid.Row="1" ColumnDefinitions="220,*">
                <!-- Menu lateral -->
                <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}" Padding="12">
                    <TextBlock Text="Menu" Foreground="{DynamicResource TextOnDarkBrush}"/>
                </Border>
                <!-- Contenido principal -->
                <Border Grid.Column="1" Background="{DynamicResource WindowSurfaceBrush}" Padding="12">
                    <TextBlock Text="{Binding Greeting}" HorizontalAlignment="Center" 
                               VerticalAlignment="Center" Foreground="{DynamicResource TextOnDarkBrush}"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
